{
  "id": "dependency-inspector",
  "name": "Dependency Inspector",
  "version": "1.1.0",
  "description": "Scan repos for vulnerable, outdated, and unlicensed dependencies with health scoring",
  "icon": "shield-check",
  "tint": "34, 197, 94",
  "instructions": "instructions.md",
  "aiKeywords": [
    "dependencies",
    "packages",
    "npm",
    "nuget",
    "vulnerabilities",
    "outdated",
    "license",
    "audit",
    "security",
    "CVE"
  ],
  "activationConditions": {
    "always": true
  },
  "settings": [
    {
      "key": "npmRegistryUrl",
      "label": "npm Registry URL",
      "description": "Custom npm registry (leave blank for default npmjs.org).",
      "placeholder": "https://registry.npmjs.org"
    },
    {
      "key": "licenseWhitelist",
      "label": "Allowed Licenses",
      "description": "Comma-separated list of approved licenses.",
      "placeholder": "MIT, Apache-2.0, BSD-2-Clause, BSD-3-Clause, ISC"
    }
  ],
  "contributions": {
    "centerTabs": [
      {
        "id": "dashboard",
        "label": "Dependencies",
        "icon": "shield-check",
        "html": "tab.html"
      }
    ],
    "routes": "routes.js"
  }
}
