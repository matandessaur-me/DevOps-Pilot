{
  "id": "sentry",
  "name": "Sentry Error Tracker",
  "version": "1.1.0",
  "description": "Monitor application errors via Sentry -- view issues, stack traces, trends, and create work items from errors",
  "icon": "bug",
  "tint": "226, 100, 80",
  "instructions": "instructions.md",
  "aiKeywords": [
    "sentry",
    "error",
    "bug",
    "crash",
    "exception",
    "stack trace",
    "error tracking",
    "monitoring",
    "issues"
  ],
  "activationConditions": {
    "always": true
  },
  "settings": [
    {
      "key": "authToken",
      "label": "Auth Token",
      "description": "Sentry auth token with project:read and issue:read/write scopes.",
      "placeholder": "sntrys_...",
      "secret": true
    },
    {
      "key": "organization",
      "label": "Organization",
      "description": "Sentry organization slug (from your Sentry URL).",
      "placeholder": "my-org"
    },
    {
      "key": "defaultProject",
      "label": "Default Project",
      "description": "Default Sentry project slug (optional).",
      "placeholder": "my-project"
    }
  ],
  "contributions": {
    "centerTabs": [
      {
        "id": "dashboard",
        "label": "Sentry",
        "icon": "bug",
        "html": "tab.html"
      }
    ],
    "routes": "routes.js"
  }
}
